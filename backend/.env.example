# Supabase server configuration. Never expose the secret key to the frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Browser and redirect origins.
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Optional Training Builder PDF import configuration.
OPENAI_API_KEY=
PROGRAM_IMPORT_MODEL=

# Optional Stripe test-mode configuration. Live keys are not permitted here.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Development/preview seed guard and dedicated fake-data accounts.
CVF_SEED_ENV=development
CVF_SEED_CONFIRM_DEVELOPMENT=false
CVF_SEED_ALLOWED_HOSTS=
CVF_SEED_ADMIN_EMAIL=
CVF_SEED_ADMIN_PASSWORD=
CVF_SEED_COACH_A_EMAIL=
CVF_SEED_COACH_A_PASSWORD=
CVF_SEED_COACH_B_EMAIL=
CVF_SEED_COACH_B_PASSWORD=
CVF_SEED_CLIENT_EMAIL=
CVF_SEED_CLIENT_PASSWORD=
