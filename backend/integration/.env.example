# Explicit non-production target. A remote hostname must also be allowlisted.
CVF_TEST_ENV=development
CVF_TEST_BASE_URL=http://localhost:8001/api
CVF_TEST_ALLOWED_HOSTS=
CVF_TEST_ALLOW_MUTATIONS=false
CVF_TEST_SUPABASE_ALLOWED_HOSTS=
CVF_TEST_LABEL_PREFIX="CVF TEST"
# Optional for Vercel deployments protected by an automation bypass secret.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Dedicated fake-data accounts. Never use real client identities.
CVF_TEST_ADMIN_EMAIL=
CVF_TEST_ADMIN_PASSWORD=
CVF_TEST_COACH_A_EMAIL=
CVF_TEST_COACH_A_PASSWORD=
CVF_TEST_COACH_B_EMAIL=
CVF_TEST_COACH_B_PASSWORD=
CVF_TEST_CLIENT_EMAIL=
CVF_TEST_CLIENT_PASSWORD=

# Required only for npm run test:cleanup. Use the confirmed fake-data project
# and its current sb_secret_ key through a secure, ignored environment file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
